# Telegram
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_chat_id_here"
# TELEGRAM_CHANNEL_ID="-100xxxxxxxxxxxx"   # uncomment for channel

# Primary LLM — DeepSeek
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-chat

# Backup LLM — Groq
LLM_BACKUP_PROVIDER=groq
LLM_BACKUP_API_KEY=your_groq_api_key
LLM_BACKUP_MODEL=llama-3.3-70b-versatile

# Trading config
TIMEFRAME=15m
ACCOUNT_EQUITY=50000   # funded account size — used for ATR-based position sizing
